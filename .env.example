# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
GEMINI_SESSION_PROMPT_PATH=./prompts/gemini_session.md

# OpenClaw Configuration
OPENCLAW_WS_URL=ws://127.0.0.1:18789
OPENCLAW_API_KEY=your_openclaw_bearer_token_here
OPENCLAW_AGENT_NAME=Rook

# Audio Configuration
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_CHUNK_SIZE=1024
# Leave empty for default device (comment out or remove line)
# AUDIO_DEVICE_INDEX=

# Database Configuration
DATABASE_PATH=./data/rook.db

# UI Configuration
UI_REFRESH_RATE=30
UI_BORDER_COLOR=magenta
UI_WAVEFORM_COLOR=green
UI_ORB_COLOR=red

# Voice Configuration
VOICE_ACTIVATION_KEY=space
BARGE_IN_THRESHOLD=0.3
VOICE_TIMEOUT_SECONDS=5
TTS_SAMPLE_RATE=24000

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=./data/rook.log
